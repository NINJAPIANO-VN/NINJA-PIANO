-- Hàm thực thi nạp nhạc linh hoạt dựa trên cấu trúc từng bài hát
local function PlayMusic(bpmValue, loaderUrl, songUrl)
   _G.bpm = bpmValue
   bpm = bpmValue 
   
   print("Đang tải bài hát với BPM: " .. tostring(bpmValue))
   
   pcall(function()
      loadstring(game:HttpGet(loaderUrl, true))()
   end)
   pcall(function()
      loadstring(game:HttpGet(songUrl, true))()
   end)
end
 
-- Tạo các nút bấm nhạc vào danh sách cuộn
for index, song in ipairs(Songs) do
   local Button = Instance.new("TextButton")
   local ButtonCorner = Instance.new("UICorner")
   
   Button.Name = "Song_" .. index
   Button.Parent = ScrollFrame
   Button.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
   Button.Size = UDim2.new(1, -6, 0, 40)
   Button.Font = Enum.Font.SourceSansSemibold
   Button.Text = "  " .. song.Name .. " (BPM: " .. tostring(song.BPM) .. ")"
   Button.TextColor3 = Color3.fromRGB(230, 230, 230)
   Button.TextSize = 14
   Button.TextXAlignment = Enum.TextXAlignment.Left 
   
   ButtonCorner.CornerRadius = UDim.new(0, 6)
   ButtonCorner.Parent = Button
   
   -- Hiệu ứng rê chuột vào nút
   Button.MouseEnter:Connect(function()
      Button.BackgroundColor3 = Color3.fromRGB(70, 70, 85)
   end)
   Button.MouseLeave:Connect(function()
      Button.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
   end)
   
   -- Xử lý click chọn bài
   Button.MouseButton1Click:Connect(function()
      local originalText = Button.Text
      
      -- Đã trả lại câu thông báo chuẩn gu của bạn
      Button.Text = "  ⏳ Đang chuẩn bị đánh piano⏳: " .. song.Name .. "..."
      Button.BackgroundColor3 = Color3.fromRGB(100, 80, 40)
      
      PlayMusic(song.BPM, song.LoaderUrl, song.SongUrl)
      
      task.wait(1)
      Button.Text = originalText
      Button.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
   end)
end
 
-- Bấm RightShift để Ẩn/Hiện bảng nhạc khi chơi game
local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessed)
   if not gameProcessed and input.KeyCode == Enum.KeyCode.RightShift then
      MainFrame.Visible = not MainFrame.Visible
   end
end)
