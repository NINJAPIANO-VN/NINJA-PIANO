-- Khởi tạo ScreenGui độc lập để không bị mất khi hồi sinh (Reset)
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local Title = Instance.new("TextLabel")
local ScrollFrame = Instance.new("ScrollingFrame")
local UIListLayout = Instance.new("UIListLayout")
local UICorner = Instance.new("UICorner")
 
-- Thiết lập Thuộc tính cho ScreenGui
ScreenGui.Name = "MusicSelectorGUI"
ScreenGui.Parent = game:GetService("CoreGui") or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false
 
-- Giao diện chính (Main Frame)
MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
MainFrame.Position = UDim2.new(0.5, -190, 0.4, -220)
MainFrame.Size = UDim2.new(0, 380, 0, 470)
MainFrame.Active = true
MainFrame.Draggable = true 
 
local FrameCorner = Instance.new("UICorner")
FrameCorner.CornerRadius = UDim.new(0, 10)
FrameCorner.Parent = MainFrame
 
-- Tiêu đề GUI
Title.Name = "Title"
Title.Parent = MainFrame
Title.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
Title.Size = UDim2.new(1, 0, 0, 100) 
Title.Font = Enum.Font.SourceSansBold
Title.Text = [[🎵 BẢNG NHẠC UPDATE ĐẦY ĐỦ 🇻🇳 🌎
(Cre script làm ra tất cả GEMINI, nhưng tôi thích ghi nguồn nhé :))) (@d4rkninja_1 lẫn 2) và cre nhạc việt @hello007568 - vài nhạc tôi lấy ổng hoặc của tôi nhé anh em ơi :D (Mà tôi cũng ko bt nhạc nào của tôi và của ổng nên kệ đi) mà liên hệ bên DISCORD hết KHÔNG MXH NÀO HẾT)]]
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 10
Title.TextWrapped = true
 
local TitleCorner = Instance.new("UICorner")
TitleCorner.CornerRadius = UDim.new(0, 10)
TitleCorner.Parent = Title
 
-- Khung cuộn danh sách nhạc (Scrolling Frame)
ScrollFrame.Name = "ScrollFrame"
ScrollFrame.Parent = MainFrame
ScrollFrame.Active = true
ScrollFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
ScrollFrame.BackgroundTransparency = 1
ScrollFrame.Position = UDim2.new(0, 10, 0, 110) 
ScrollFrame.Size = UDim2.new(1, -20, 1, -120)
ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
ScrollFrame.ScrollBarThickness = 6
 
UIListLayout.Parent = ScrollFrame
UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
UIListLayout.Padding = UDim.new(0, 8)
 
UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
   ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end)
 
